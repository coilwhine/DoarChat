{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "doar-chat",
    "Audience": "doar-chat-users",
    "ExpiryMinutes": 60
  },
  "UserStore": {
    "FilePath": "Data/users.json"
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=DoarChat;Trusted_Connection=True;TrustServerCertificate=True"
  }
}
